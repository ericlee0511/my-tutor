{
  "title": "Una visita al supermercado",
  "all": [
    {
      "es": "Hoy voy al supermercado con mi hermana.",
      "zh": "今天我和姊姊去超市。"
    },
    {
      "es": "Necesitamos pan, leche y fruta.",
      "zh": "我們需要麵包，牛奶和水果。"
    },
    {
      "es": "Buenos días, ¿dónde está el pan?",
      "zh": "早安，麵包在哪裡？"
    },
    {
      "es": "Está al fondo, a la derecha.",
      "zh": "在後面，右邊。"
    },
    {
      "es": "Muchas gracias, señora.",
      "zh": "非常感謝，女士。"
    },
    {
      "es": "Mi hermana coge dos botellas de leche.",
      "zh": "我姊姊拿了兩瓶牛奶。"
    },
    {
      "es": "Yo cojo manzanas rojas y plátanos.",
      "zh": "我拿了紅蘋果和香蕉。"
    },
    {
      "es": "También compramos queso y jamón.",
      "zh": "我們也買了起司和火腿。"
    },
    {
      "es": "¿Cuánto es todo?",
      "zh": "總共多少錢？"
    },
    {
      "es": "Son quince euros con cincuenta.",
      "zh": "十五歐元五十分。"
    },
    {
      "es": "Pago con tarjeta y guardamos la compra en una bolsa.",
      "zh": "我用卡片付款，我們把買的東西放進袋子裡。"
    },
    {
      "es": "Volvemos a casa muy contentas.",
      "zh": "我們很開心地回家。"
    }
  ]
}
